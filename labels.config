// labels.config
process {
    withLabel: big_mem {
        // For memory-intensive jobs: MEGAHIT assembly, Kaiju
        cpus   = 96
        memory = 400.GB
    }
    withLabel: process_high {
        // CPU/memory-intensive tools: bowtie2, minimap2, bwa, CAT (diamond), minimap2_index
        // Memory raised from 70 GB to accommodate CAT/diamond
        cpus   = 42
        memory = 120.GB
    }
    withLabel: med_mem {
        // Moderate tools: trimmomatic, samtools, kraken2
        cpus   = 20
        memory = 64.GB
    }
    withLabel: min_mem {
        // Lightweight tasks: bracken, load_k2_db, cat_add_names, concat_fastq
        cpus   = 4
        memory = 16.GB
    }
}